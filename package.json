{
  "name": "mochi-social",
  "version": "0.1.0",
  "private": true,
  "description": "Mochi Social Unity WebGL shared-room runtime kept separate from its future Vercel/Supabase website.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=24.17.0 <25"
  },
  "workspaces": [
    "apps/game"
  ],
  "scripts": {
    "prepare-assets": "node apps/game/scripts/generate-assets.mjs",
    "dev:game": "npm run dev:unity",
    "dev:unity": "npm run unity:open",
    "dev:legacy": "npm run prepare-assets && npm --workspace @mochi-social/game run dev",
    "build": "npm run build:server",
    "build:server": "npm run prepare-assets && npm --workspace @mochi-social/game run build",
    "build:release": "npm run build:server && npm run unity:build:webgl",
    "unity:open": "node scripts/run-unity.mjs open",
    "unity:bootstrap": "node scripts/run-unity.mjs bootstrap",
    "unity:test:editmode": "node scripts/run-unity.mjs test-editmode",
    "unity:test:playmode": "node scripts/run-unity.mjs test-playmode",
    "unity:build:webgl": "node scripts/run-unity.mjs build-webgl",
    "unity:cloud-code-contract": "node scripts/check-unity-cloud-code-contract.mjs",
    "unity:verify": "node scripts/run-unity.mjs verify",
    "start": "npm --workspace @mochi-social/game run start",
    "clean-room-scan": "node scripts/check-clean-room-literals.mjs",
    "secret-scan": "node scripts/check-secrets.mjs",
    "alpha:public-copy": "node scripts/check-alpha-public-copy.mjs",
    "alpha:readiness": "node scripts/check-alpha-readiness.mjs",
    "alpha:monero-treasury": "node scripts/check-monero-treasury-guardrails.mjs",
    "alpha:monero-operator-handoff": "node scripts/write-monero-operator-handoff.mjs",
    "alpha:local-acceptance": "node scripts/check-local-alpha-acceptance.mjs",
    "alpha:load-smoke": "node scripts/check-alpha-load-smoke.mjs",
    "alpha:browser-presence": "node scripts/check-alpha-browser-presence.mjs",
    "alpha:browser-bridge-auth": "node scripts/check-alpha-browser-bridge-auth.mjs",
    "alpha:responsive-gameplay": "node scripts/check-alpha-responsive-gameplay.mjs",
    "alpha:local-site-iframe": "node scripts/check-alpha-local-site-iframe.mjs",
    "alpha:visual-snapshot": "node scripts/check-alpha-visual-snapshot.mjs",
    "alpha:visual-review": "node scripts/check-alpha-visual-review.mjs",
    "alpha:manual-prompt-review": "node scripts/write-alpha-manual-prompt-review.mjs",
    "alpha:wallet-daemon-check": "node scripts/check-wallet-daemon-local.mjs",
    "alpha:enjin-operator-smoke": "node scripts/check-enjin-operator-smoke.mjs",
    "alpha:built-server-smoke": "node scripts/check-built-server-smoke.mjs",
    "alpha:local-suite": "node scripts/check-alpha-local-suite.mjs",
    "alpha:local-evidence": "node scripts/check-alpha-local-evidence.mjs",
    "alpha:report-hygiene": "node scripts/check-alpha-report-hygiene.mjs",
    "alpha:site-repo-path": "node scripts/check-alpha-site-repo-path.mjs",
    "alpha:gate-contracts": "node scripts/check-alpha-gate-contracts.mjs",
    "alpha:preview-ready": "node scripts/check-alpha-preview-ready.mjs",
    "alpha:external-gates": "node scripts/check-alpha-external-gates.mjs",
    "alpha:operator-checklist": "node scripts/write-alpha-operator-checklist.mjs",
    "alpha:provider-preflight": "node scripts/write-alpha-provider-preflight.mjs",
    "alpha:sync-approval": "node scripts/write-alpha-sync-approval.mjs",
    "alpha:sync-approval-self-test": "node scripts/check-alpha-sync-approval-self-test.mjs",
    "alpha:branch-inventory": "node scripts/check-alpha-branch-inventory.mjs",
    "alpha:rc-audit": "node scripts/check-alpha-rc-audit.mjs",
    "typecheck": "npm --workspace @mochi-social/game run typecheck",
    "lint": "npm --workspace @mochi-social/game run lint",
    "test": "npm --workspace @mochi-social/game run test",
    "smoke": "npm --workspace @mochi-social/game run smoke"
  },
  "devDependencies": {
    "playwright-core": "^1.60.0"
  }
}
